# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Pilot riêng cho module B2B nâng cao.
# Bỏ trống nếu chỉ chạy localStorage; không dùng chung URL với production.
NEXT_PUBLIC_PILOT_SUPABASE_URL=
NEXT_PUBLIC_PILOT_SUPABASE_ANON_KEY=

# Service Role Key (server-side only, used for auth verification bypassing RLS)
# Get this from: Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Distributed API rate limiting (optional but recommended in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sinh types/database.generated.ts từ DB thật (npm run gen:types)
# Cần SUPABASE_SERVICE_ROLE_KEY ở trên.

# E2E Playwright (npm run test:e2e) — tùy chọn
# PLAYWRIGHT_BASE_URL=http://localhost:3000
