# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Pilot riêng cho module B2B nâng cao.
# Bỏ trống nếu chỉ chạy localStorage; không dùng chung URL với production.
NEXT_PUBLIC_PILOT_SUPABASE_URL=
NEXT_PUBLIC_PILOT_SUPABASE_ANON_KEY=

# Service Role Key (server-side only, used for auth verification bypassing RLS)
# Get this from: Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
